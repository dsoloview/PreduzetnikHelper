<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="UTF-8">
    <title>Faktura {{displayNumber}}</title>
    <style>
        body {
            font-family: 'Helvetica Neue', 'Helvetica', Helvetica, Arial, sans-serif;
            color: #333;
            margin: 0;
            padding: 14px;
            font-size: 12px;
        }
        p { margin: 2px 0; }
        .header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 14px;
            border-bottom: 2px solid #333;
            padding-bottom: 10px;
        }
        .company-info {
            width: 50%;
        }
        .invoice-details {
            width: 50%;
            text-align: right;
        }
        h1 {
            color: #2c3e50;
            margin-top: 0;
            margin-bottom: 3px;
            font-size: 20px;
        }
        h2 {
            margin: 2px 0;
            font-size: 14px;
        }
        .details-section {
            display: flex;
            justify-content: space-between;
            margin-bottom: 14px;
        }
        .client-info {
            width: 45%;
            padding: 8px 10px;
            background: #f9f9f9;
            border-radius: 4px;
        }
        .client-info h3 {
            margin-top: 0;
            margin-bottom: 4px;
            font-size: 12px;
            color: #2c3e50;
            border-bottom: 1px solid #ccc;
            padding-bottom: 3px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 12px;
        }
        th, td {
            padding: 6px 8px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }
        th {
            background-color: #2c3e50;
            color: white;
            font-weight: bold;
            font-size: 11px;
        }
        td.text-right, th.text-right {
            text-align: right;
        }
        .totals {
            width: 45%;
            float: right;
            margin-bottom: 14px;
        }
        .totals-row {
            display: flex;
            justify-content: space-between;
            padding: 4px 0;
            border-bottom: 1px solid #eee;
        }
        .totals-row.grand-total {
            font-size: 14px;
            font-weight: bold;
            border-bottom: 2px solid #333;
            border-top: 2px solid #333;
        }
        .clear {
            clear: both;
        }
        .footer {
            margin-top: 16px;
            padding-top: 8px;
            border-top: 1px solid #ccc;
            font-size: 10px;
            color: #777;
            text-align: center;
        }
        .note {
            margin-top: 10px;
            padding: 8px 10px;
            background-color: #f0f7fb;
            border-left: 4px solid #3498db;
        }
        .pdv-note {
            font-weight: bold;
            margin-top: 10px;
            font-size: 11px;
            font-style: italic;
        }
    </style>
</head>
<body>

    <div class="header">
        <div class="company-info">
            <h1>{{user.companyName}}</h1>
            <p><strong>Ime i prezime / Name:</strong> {{user.name}}</p>
            <p><strong>Adresa / Address:</strong> {{user.address}}, {{user.city}}</p>
            <p><strong>PIB / Tax ID:</strong> {{user.pib}} | <strong>MB / Reg. No:</strong> {{user.mbr}}</p>
        </div>
        <div class="invoice-details">
            <h1 style="color: #7f8c8d;">FAKTURA / INVOICE</h1>
            <h2>Br. / No. {{displayNumber}}</h2>
            <p><strong>Mesto izdavanja / Place of Issue:</strong> {{placeOfIssue}}</p>
            <p><strong>Datum izdavanja / Issue Date:</strong> {{formatDate issueDate}}</p>
            <p><strong>Datum prometa / Supply Date:</strong> {{formatDate issueDate}}</p>
            <p><strong>Rok plaćanja / Due Date:</strong> {{formatDate dueDate}}</p>
        </div>
    </div>

    <div class="details-section">
        <div class="client-info">
            <h3>Kupac / Klijent</h3>
            <p><strong>{{client.name}}</strong></p>
            <p>{{client.address}}</p>
            <p>{{client.city}}, {{client.country}}</p>
            {{#if client.taxId}}<p><strong>PIB / Tax ID:</strong> {{client.taxId}}</p>{{/if}}
            {{#if client.registrationNumber}}<p><strong>MB / Reg. No:</strong> {{client.registrationNumber}}</p>{{/if}}
        </div>
        
        <div class="client-info">
            <h3>Uplate izvršiti na / Payment to:</h3>
            <p><strong>Banka / Bank:</strong> {{bankAccount.bankName}}</p>
            <p><strong>Broj računa / Account No:</strong> {{bankAccount.accountNumber}}</p>
            {{#if bankAccount.swiftCode}}<p><strong>SWIFT / BIC:</strong> {{bankAccount.swiftCode}}</p>{{/if}}
            {{#if bankAccount.iban}}<p><strong>IBAN:</strong> {{bankAccount.iban}}</p>{{/if}}
            <p><strong>Valuta / Currency:</strong> {{currency}}</p>
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th>R.br. / No.</th>
                <th>Opis usluge / Description</th>
                <th class="text-right">Količina / Qty</th>
                <th class="text-right">Cena / Unit Price ({{currency}})</th>
                <th class="text-right">Ukupno / Total ({{currency}})</th>
            </tr>
        </thead>
        <tbody>
            {{#each items}}
            <tr>
                <td>{{@index}}</td>
                <td>{{this.description}}</td>
                <td class="text-right">{{this.quantity}}</td>
                <td class="text-right">{{formatCurrency this.unitPrice}}</td>
                <td class="text-right">{{formatCurrency this.total}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>

    <div class="totals">
        <div class="totals-row">
            <span>Osnovica / Base:</span>
            <span>{{formatCurrency totalAmount}} {{currency}}</span>
        </div>
        <div class="totals-row">
            <span>PDV / VAT (0%):</span>
            <span>0.00 {{currency}}</span>
        </div>
        <div class="totals-row grand-total">
            <span>Za uplatu / Total Due:</span>
            <span>{{formatCurrency totalAmount}} {{currency}}</span>
        </div>
        
        {{#if exchangeRate}}
        <div class="totals-row" style="color: #777; font-size: 12px; margin-top: 10px;">
            <span>Protivvrednost / RSD equivalent (KPO):</span>
            <span>{{formatCurrency totalRsd}} RSD (Kurs / Rate: {{exchangeRate}})</span>
        </div>
        {{/if}}
    </div>
    <div class="clear"></div>

    <div class="pdv-note">
        Preduzetnik nije u sistemu PDV-a prema članu 33. Zakona o PDV-u.<br>
        <span style="font-weight: normal; font-style: normal;">Not subject to VAT per Article 33 of the VAT Law.</span>
    </div>

    {{#if note}}
    <div class="note">
        <strong>Napomena / Note:</strong><br>
        {{note}}
    </div>
    {{/if}}

    <div class="footer">
        Faktura je validna bez pečata i potpisa. / This invoice is valid without stamp and signature.<br>
        Generisano pomoću PreduzetnikHelper aplikacije.
    </div>

</body>
</html>
