<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="UTF-8">
    <title>Faktura {{displayNumber}}</title>
    <style>
        body {
            font-family: 'Helvetica Neue', 'Helvetica', Helvetica, Arial, sans-serif;
            color: #333;
            margin: 0;
            padding: 20px;
            font-size: 14px;
        }
        .header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 40px;
            border-bottom: 2px solid #333;
            padding-bottom: 20px;
        }
        .company-info {
            width: 50%;
        }
        .invoice-details {
            width: 50%;
            text-align: right;
        }
        h1 {
            color: #2c3e50;
            margin-top: 0;
            margin-bottom: 5px;
            font-size: 28px;
        }
        .details-section {
            display: flex;
            justify-content: space-between;
            margin-bottom: 40px;
        }
        .client-info {
            width: 45%;
            padding: 15px;
            background: #f9f9f9;
            border-radius: 5px;
        }
        .client-info h3 {
            margin-top: 0;
            color: #2c3e50;
            border-bottom: 1px solid #ccc;
            padding-bottom: 5px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }
        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }
        th {
            background-color: #2c3e50;
            color: white;
            font-weight: bold;
        }
        td.text-right, th.text-right {
            text-align: right;
        }
        .totals {
            width: 50%;
            float: right;
            margin-bottom: 40px;
        }
        .totals-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid #eee;
        }
        .totals-row.grand-total {
            font-size: 18px;
            font-weight: bold;
            border-bottom: 2px solid #333;
            border-top: 2px solid #333;
        }
        .clear {
            clear: both;
        }
        .footer {
            margin-top: 50px;
            padding-top: 20px;
            border-top: 1px solid #ccc;
            font-size: 12px;
            color: #777;
            text-align: center;
        }
        .note {
            margin-top: 30px;
            padding: 15px;
            background-color: #f0f7fb;
            border-left: 4px solid #3498db;
        }
        .pdv-note {
            font-weight: bold;
            margin-top: 20px;
            font-style: italic;
        }
    </style>
</head>
<body>

    <div class="header">
        <div class="company-info">
            <h1>{{user.companyName}}</h1>
            <p><strong>Ime i prezime:</strong> {{user.name}}</p>
            <p><strong>Adresa:</strong> {{user.address}}, {{user.city}}</p>
            <p><strong>PIB:</strong> {{user.pib}} | <strong>MB:</strong> {{user.mbr}}</p>
        </div>
        <div class="invoice-details">
            <h1 style="color: #7f8c8d;">FAKTURA</h1>
            <h2>Br. {{displayNumber}}</h2>
            <p><strong>Mesto izdavanja:</strong> {{placeOfIssue}}</p>
            <p><strong>Datum izdavanja:</strong> {{formatDate issueDate}}</p>
            <p><strong>Datum prometa:</strong> {{formatDate issueDate}}</p>
            <p><strong>Rok plaćanja:</strong> {{formatDate dueDate}}</p>
        </div>
    </div>

    <div class="details-section">
        <div class="client-info">
            <h3>Kupac / Klijent</h3>
            <p><strong>{{client.name}}</strong></p>
            <p>{{client.address}}</p>
            <p>{{client.city}}, {{client.country}}</p>
            {{#if client.taxId}}<p><strong>PIB / Tax ID:</strong> {{client.taxId}}</p>{{/if}}
            {{#if client.registrationNumber}}<p><strong>MB / Reg. No:</strong> {{client.registrationNumber}}</p>{{/if}}
        </div>
        
        <div class="client-info">
            <h3>Uplate izvršiti na:</h3>
            <p><strong>Banka:</strong> {{bankAccount.bankName}}</p>
            <p><strong>Broj računa:</strong> {{bankAccount.accountNumber}}</p>
            <p><strong>Valuta:</strong> {{currency}}</p>
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th>R.br.</th>
                <th>Opis usluge</th>
                <th class="text-right">Količina</th>
                <th class="text-right">Cena ({{currency}})</th>
                <th class="text-right">Ukupno ({{currency}})</th>
            </tr>
        </thead>
        <tbody>
            {{#each items}}
            <tr>
                <td>{{@index}}</td>
                <td>{{this.description}}</td>
                <td class="text-right">{{this.quantity}}</td>
                <td class="text-right">{{formatCurrency this.unitPrice}}</td>
                <td class="text-right">{{formatCurrency this.total}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>

    <div class="totals">
        <div class="totals-row">
            <span>Osnovica:</span>
            <span>{{formatCurrency totalAmount}} {{currency}}</span>
        </div>
        <div class="totals-row">
            <span>PDV (0%):</span>
            <span>0.00 {{currency}}</span>
        </div>
        <div class="totals-row grand-total">
            <span>Za uplatu:</span>
            <span>{{formatCurrency totalAmount}} {{currency}}</span>
        </div>
        
        {{#if exchangeRate}}
        <div class="totals-row" style="color: #777; font-size: 12px; margin-top: 10px;">
            <span>Protivvrednost (za KPO):</span>
            <span>{{formatCurrency totalRsd}} RSD (Kurs: {{exchangeRate}})</span>
        </div>
        {{/if}}
    </div>
    <div class="clear"></div>

    <div class="pdv-note">
        Preduzetnik nije u sistemu PDV-a prema članu 33. Zakona o PDV-u.
    </div>

    {{#if note}}
    <div class="note">
        <strong>Napomena:</strong><br>
        {{note}}
    </div>
    {{/if}}

    <div class="footer">
        Faktura je validna bez pečata i potpisa.<br>
        Generisano pomoću PreduzetnikHelper aplikacije.
    </div>

</body>
</html>
