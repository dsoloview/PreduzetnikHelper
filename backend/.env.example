# ─── Local Development ────────────────────────────────────────────────────────
# Copy this file to backend/.env and fill in the values.
# For Docker-based setup, use the root .env instead.

# PostgreSQL — must match the credentials used in docker-compose.yml or your local DB
DATABASE_URL=postgresql://preduzetnik:change-me@localhost:5432/preduzetnik?schema=public

# JWT — use long random strings (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret
REFRESH_TOKEN_EXPIRES_DAYS=30

# Allowed frontend origin
CORS_ORIGIN=http://localhost:5173

# PDF provider: "pdfmake" (no Chrome required) or "puppeteer"
PDF_PROVIDER=pdfmake
