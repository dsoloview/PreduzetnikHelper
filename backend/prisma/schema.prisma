// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Currency {
  RSD
  EUR
  USD
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  name         String
  // Serbian business details
  companyName  String?       @map("company_name")
  pib          String?       @unique // Poreski identifikacioni broj (Tax ID)
  mbr          String?       @unique // Matični broj registracije
  activityCode String?       @map("activity_code") // Šifra delatnosti
  address      String?
  city         String?
  postalCode   String?  @map("postal_code")
  municipality String? // Opština — affects tax coefficient
  phone        String?
  bankAccounts   BankAccount[]
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  clients        Client[]
  invoices       Invoice[]
  refreshTokens  RefreshToken[]

  @@map("users")
}

model BankAccount {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  bankName      String    @map("bank_name")
  accountNumber String    @map("account_number") // Format: XXX-XXXXXXXXXX-XX
  swiftCode     String?   @map("swift_code")
  iban          String?
  currency      Currency  @default(RSD)
  isDefault     Boolean   @default(false) @map("is_default")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  invoices      Invoice[]

  @@map("bank_accounts")
}

enum ClientType {
  DOMESTIC // Serbian client — taxId = PIB
  INTERNATIONAL // Foreign client — taxId = VAT/EIN/etc
}

model Client {
  id                 String     @id @default(uuid())
  userId             String     @map("user_id")
  type               ClientType @default(DOMESTIC)
  name               String
  email              String?
  phone              String?
  address            String
  city               String
  postalCode         String?    @map("postal_code")
  country            String     @default("RS") // ISO 3166-1 alpha-2
  taxId              String     @map("tax_id") // PIB for Serbian, VAT/EIN for foreign
  registrationNumber String     @map("registration_number") // MBR for Serbian
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  invoices           Invoice[]

  @@map("clients")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

model Invoice {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  clientId       String        @map("client_id")
  invoiceNumber  Int           @map("invoice_number") // Sequential per user per year
  year           Int // Year for numbering (e.g. 2026)
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime      @map("issue_date")
  dueDate        DateTime      @map("due_date")
  placeOfIssue   String        @default("Beograd") @map("place_of_issue")
  domesticSupply Boolean       @default(true) @map("domestic_supply")
  // true = mesto prometa u Srbiji → counts toward 8M
  // false = mesto prometa van Srbije → does NOT count toward 8M
  currency       Currency      @default(RSD)
  exchangeRate   Decimal?      @map("exchange_rate") // NBS rate if non-RSD
  totalAmount    Decimal       @map("total_amount") // In invoice currency
  totalRsd       Decimal       @map("total_rsd") // Always in RSD (for KPO)
  note           String?
  bankAccountId  String        @map("bank_account_id")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  bankAccount    BankAccount   @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  items          InvoiceItem[]
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@unique([userId, invoiceNumber, year]) // 1/2026 unique per user
  @@map("invoices")
}

model RefreshToken {
  id          String   @id @default(uuid())
  jti         String   @unique
  userId      String   @map("user_id")
  hashedToken String   @map("hashed_token")
  expiresAt   DateTime @map("expires_at")
  userAgent   String?  @map("user_agent")
  ip          String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

model ExchangeRate {
  id           String   @id @default(uuid())
  currencyCode String   @map("currency_code") // "EUR", "USD"
  date         DateTime @db.Date              // rate date (no time)
  middleRate   Decimal  @map("middle_rate")   // NBS middle rate (srednji kurs)
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([currencyCode, date])
  @@map("exchange_rates")
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String  @map("invoice_id")
  description String
  quantity    Decimal
  unitPrice   Decimal @map("unit_price")
  total       Decimal // quantity * unitPrice
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}
