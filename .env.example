# PostgreSQL
POSTGRES_USER=preduzetnik
POSTGRES_PASSWORD=change-me
POSTGRES_DB=preduzetnik

# Backend (for local dev without Docker use localhost:5432, Docker sets this automatically)
DATABASE_URL=postgresql://preduzetnik:change-me@localhost:5432/preduzetnik

JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret
REFRESH_TOKEN_EXPIRES_DAYS=30

# Docker: http://localhost, local dev: http://localhost:5173
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Port exposed by Docker frontend container (default: 80)
APP_PORT=80
